{% extends 'base/page.html.twig' %}

{% block body %}
<div class="card">
	<div class="card-header">
		<h3 class="card-title">{{ "Reports"|trans }}</h3>
	</div>
	<div class="table-responsive">
		<table class="table card-table table-vcenter text-nowrap datatable">
			<thead>
				<tr>
					{# <th class="w-1"><input class="form-check-input m-0 align-middle" type="checkbox" aria-label="Select all invoices"></th> #}
					<th class="w-1">{{ "Id"|trans }}</th>
					<th>{{ "Messages"|trans }}</th>
					{# <th>{{ "Domain"|trans }}</th> #}
					<th>{{ "Date"|trans }}</th>
					<th>{{ "Reporter"|trans }}</th>
					<th>{{ "Policy"|trans }}</th>
					<th>{{ "Type"|trans }}</th>
					<th></th>
				</tr>
			</thead>

			<tbody>
{% for report in reports %}
				<tr>
					<td>
						<span class="text-secondary">{{ report.id }}</span>
						{% if app.user in report.seen %}{% else %}<span class="badge bg-yellow"></span>{% endif %}
					</td>
					<td>#{{ report.smtptls_policies.count }}</td>
					{# <td>{{ report.domain.fqdn }}</td> #}
					<td>{{ report.begintime|date("d-M-Y H:i:s") }}</td>
					<td>{{ report.organisation }}</td>
						{% set successfulcount = 0 %}
						{% set failedcount = 0 %}
						{% set sts = 0 %}
						{% set sts_v_empty = 0 %}
						{% set sts_v1 = 0 %}
						{% set tlsa = 0 %}
						{% set mode_enforce = 0 %}
						{% set mode_testing = 0 %}
						{% set mode_disabled = 0 %}
						{% for policy in report.smtptls_policies %}
							{% set successfulcount = successfulcount + policy.summarysuccessfulcount %}
							{% set failedcount = failedcount + policy.summaryfailedcount %}
							{% if policy.policytype == 'sts' %}
								{% set sts = sts + 1 %}
								{% if policy.policystringversion == 'STSv1' %}
									{% set sts_v1 = sts_v1 + 1 %}
								{% else %}
									{% set sts_v_empty = sts_v_empty + 1 %}
								{% endif %}
							{% endif %}
							{% if policy.policytype == 'tlsa' %}
								{% set tlsa = tlsa + 1 %}
							{% endif %}
							{% if policy.policystringmode == 'enforce' %}
								{% set mode_enforce = mode_enforce + 1 %}
							{% elseif policy.policystringmode == 'testing' %}
								{% set mode_testing = mode_testing + 1 %}
							{% else %}
								{% set mode_disabled = mode_disabled + 1 %}
							{% endif %}
						{% endfor %}
					<td>
						{% if successfulcount > 0 %}<span class="badge bg-green  me-1 text-white">{{ successfulcount }}</span>{% endif %}
						{% if failedcount > 0 %}<span class="badge bg-red  me-1 text-white">{{ failedcount }}</span>{% endif %}
					</td>
					<td>
						{% if sts > 0 %}<span class="badge bg-green  me-1 text-white">STS</span>{% endif %}
						{% if sts_v_empty > 0 %}<span class="badge bg-red  me-1 text-white">NoVersion</span>{% endif %}
						{% if sts_v1 > 0 %}<span class="badge bg-green  me-1 text-white">STSv1</span>{% endif %}
						{% if tlsa > 0 %}<span class="badge bg-green  me-1 text-white">TLSA</span>{% endif %}
						{% if mode_enforce > 0 %}<span class="badge bg-green  me-1 text-white">Enforce</span>{% endif %}
						{% if mode_testing > 0 %}<span class="badge bg-yellow  me-1 text-white">Testing</span>{% endif %}
						{% if mode_disabled > 0 %}<span class="badge bg-red  me-1 text-white">Disabled</span>{% endif %}
					</td>
					<td class="text-end">
						<span class="dropdown">
							<button class="btn dropdown-toggle align-text-top"{# data-bs-boundary="viewport"#} data-bs-toggle="dropdown">{{ "Actions"|trans }}</button>
							<div class="dropdown-menu dropdown-menu dropdown-menu-end">
								<a class="dropdown-item" href="{{ path('app_smtptls_reports_report', {report: report.id}) }}">{{ "Open"|trans }}</a>
								<a class="dropdown-item " href="{{ path('app_smtptls_reports_delete', {report: report.id}) }}"><span class="text-red">{{ "Delete"|trans }}</span></a>
							</div>
						</span>
					</td>
				</tr>
{% endfor %}
			</tbody>
		</table>
	</div>
	<div class="card-footer d-flex align-items-center">
		<p class="m-0 text-secondary">Showing <span>{{ pages.start }}</span> to <span>{{ pages.end }}</span> of <span>{{ pages.totalreports }}</span> entries</p>
		<ul class="pagination m-0 ms-auto">
			{% if pages.prev %}
				<li class="page-item">
					<a class="page-link" href="{{ path('app_smtptls_reports', {page: pages.page - 1, perpage: pages.perpage }) }}" tabindex="-1" aria-disabled="true">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path d="M15 6l-6 6l6 6"></path></svg>
						prev
					</a>
				</li>
			{% else %}
				<li class="page-item disabled">
					<a class="page-link" href="#" tabindex="-1" aria-disabled="true">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path d="M15 6l-6 6l6 6"></path></svg>
						prev
					</a>
				</li>
			{% endif %}
			{% if pages.total <= 5 %}
				{% for page in 1..pages.total %}
				<li class="page-item {% if page == pages.page %}active{% endif %}"><a class="page-link" href="{{ path('app_smtptls_reports', {page: page, perpage: pages.perpage }) }}">{{ page }}</a></li>
				{% endfor %}
			{% else %}
				<li class="page-item {% if page == 1 %}active{% endif %}"><a class="page-link" href="{{ path('app_smtptls_reports', {page: page, perpage: pages.perpage }) }}">1</a></li>

				{% if pages.total >= 9 %}
				{% set start_page = max(2, pages.page - 3) %}
				{% set end_page = min((pages.total -1 ), pages.page + 3) %}
				{% if start_page > 2 %}
					<li class="page-item">
						<svg  xmlns="http://www.w3.org/2000/svg"  width="24"  height="24"  viewBox="0 0 24 24"  fill="none"  stroke="currentColor"  stroke-width="2"  stroke-linecap="round"  stroke-linejoin="round"  class="page-link mt-1 icon icon-tabler icons-tabler-outline icon-tabler-dots"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 12m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0" /><path d="M12 12m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0" /><path d="M19 12m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0" /></svg>
					</li>
				{% endif %}
				{% for page in start_page..end_page %}
					<li class="page-item {% if page == pages.page %}active{% endif %}"><a class="page-link" href="{{ path('app_smtptls_reports', {page: page, perpage: pages.perpage }) }}">{{ page }}</a></li>
				{% endfor %}
				{% if end_page < (pages.total -1) %}
					<li class="page-item">
						<svg  xmlns="http://www.w3.org/2000/svg"  width="24"  height="24"  viewBox="0 0 24 24"  fill="none"  stroke="currentColor"  stroke-width="2"  stroke-linecap="round"  stroke-linejoin="round"  class="page-link mt-1 icon icon-tabler icons-tabler-outline icon-tabler-dots"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 12m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0" /><path d="M12 12m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0" /><path d="M19 12m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0" /></svg>
					</li>
				{% endif %}
				{% else %}
				{% for page in 2 .. (pages.total -1) %}
					<li class="page-item {% if page == pages.page %}active{% endif %}"><a class="page-link" href="{{ path('app_smtptls_reports', {page: page, perpage: pages.perpage }) }}">{{ page }}</a></li>
				{% endfor %}
				{% endif %}

				<li class="page-item {% if pages.page == pages.total %}active{% endif %}"><a class="page-link" href="{{ path('app_smtptls_reports', {page: pages.total, perpage: pages.perpage }) }}">{{ pages.total }}</a></li>
			{% endif %}

			{% if pages.next %}
				<li class="page-item {% if pages.page == pages.total %}active{% endif %}">
					<a class="page-link" href="{{ path('app_smtptls_reports', {page: pages.page + 1, perpage: pages.perpage }) }}">
						next
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path d="M9 6l6 6l-6 6"></path></svg>
					</a>
				</li>
			{% else %}
				<li class="page-item disabled">
					<a class="page-link" href="#">
						next
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path d="M9 6l6 6l-6 6"></path></svg>
					</a>
				</li>
			{% endif %}
		</ul>
	</div>
</div>
{% endblock %}
