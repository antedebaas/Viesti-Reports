{% extends 'base/page.html.twig' %}

{% block stylesheets %}{% endblock %}

{% block body %}
<div class="row row-deck row-cards">
	{% include 'dashboard/barchart.html.twig' with { stats: stats.dmarc, show: [['dkim_pass','green'],['dkim_fail','purple']], tag: 'dkim', title: "DKIM alignment", element: 'dkim-aligned' } %}
	{% include 'dashboard/barchart.html.twig' with { stats: stats.dmarc, show: [['spf_pass','green'] ,['spf_fail','purple']], tag: 'spf', title: "SPF alignment", element: 'spf-aligned' } %}
	{% include 'dashboard/barchart.html.twig' with { stats: stats.smtptls, show: [['policy_sts','green'],['policy_nopolicy','grey']], tag: 'policy', title: "STS-Policy alignment", element: 'policy-aligned' } %}
	{% include 'dashboard/barchart.html.twig' with { stats: stats.smtptls, show: [['stsmode_enforce','green'],['stsmode_testing','yellow'],['stsmode_none','purple']], tag: 'stsmode',  title: "STS-Mode alignment",  element: 'stsmode-aligned' } %}

{% endblock %}

{% block javascripts_footer %}
<script src="/apexcharts-3.54.0-dist/apexcharts.min.js" defer></script>
{% endblock %}